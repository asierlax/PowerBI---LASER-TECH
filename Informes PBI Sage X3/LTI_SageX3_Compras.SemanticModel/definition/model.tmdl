model Model
	culture: es-ES
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: es-ES
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

queryGroup Ayuda

	annotation PBI_QueryGroupOrder = 0

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["Recurso","Metricas","UltimaActualizacion","Instancia","BaseDeDatos","Esquema","fact_FacturasCompra","dim_Articulos","dim_Calendario","dim_Proveedores","dim_Sociedades","fact_Recepciones","dim_Direcciones","fact_PedidosCompra"]

annotation PBI_ProTooling = ["DevMode"]

ref table Metricas
ref table UltimaActualizacion
ref table fact_FacturasCompra
ref table dim_Articulos
ref table dim_Calendario
ref table dim_Proveedores
ref table dim_Sociedades
ref table fact_Recepciones
ref table dim_Direcciones
ref table fact_PedidosCompra

ref cultureInfo es-ES

