model Model
	culture: es-ES
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: es-ES
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

queryGroup Ayuda

	annotation PBI_QueryGroupOrder = 0

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["Factura Compras","Lineas Contables Analiticas","Proveedor","Recurso","Direccion","Fecha","Articulos","Empresa","Metricas","UltimaActualizacion","Instancia","BaseDeDatos","Esquema","Pedidos Cabecera","Pedidos Lineas","Recepciones","fact_FacturasCompra","dim_Articulos","dim_Calendario","dim_Proveedores","dim_Sociedades","fact_Recepciones","dim_Direcciones","fact_PedidosCompra"]

annotation PBI_ProTooling = ["DevMode"]

ref table 'Factura Compras'
ref table Proveedor
ref table Direccion
ref table Fecha
ref table Articulos
ref table Empresa
ref table Metricas
ref table UltimaActualizacion
ref table 'Lineas Contables Analiticas'
ref table 'Pedidos Cabecera'
ref table 'Pedidos Lineas'
ref table Recepciones
ref table fact_FacturasCompra
ref table dim_Articulos
ref table dim_Calendario
ref table dim_Proveedores
ref table dim_Sociedades
ref table fact_Recepciones
ref table dim_Direcciones
ref table fact_PedidosCompra

ref cultureInfo es-ES

