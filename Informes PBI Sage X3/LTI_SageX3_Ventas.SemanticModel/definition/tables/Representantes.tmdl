	partition Representantes-66b70925-f506-4382-b29e-82b103a88725 = m
		mode: import
		source =
				let
				    CurrentServer = Instancia,
				    CurrentDatabase = BaseDeDatos,
				    CurrentSchema = Esquema,
				    Origen = Sql.Database(CurrentServer, CurrentDatabase, [Query="
				                                                                SELECT  REPNUM_0 AS 'Comercial',
				                                                                        REPNAM_0 AS 'Nombre Comercial',
				                                                                        AUSNUM_0 AS 'Codigo Usuario',
				                                                                        CFY_0 AS 'Empresa',
				                                                                        CUR_0 AS 'Moneda',
				                                                                        BPAADD_0 AS 'Direccion',
				                                                                        (REPNUM_0+'-'+BPAADD_0) AS 'IdDireccion'
				                                                                FROM " & CurrentSchema & ".SALESREP"
				                                                          ])
				in
				    #"Origen"

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

