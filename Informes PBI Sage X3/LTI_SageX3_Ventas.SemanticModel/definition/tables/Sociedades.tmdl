	partition Sociedades-30c7b845-79ce-417a-a075-ef408ab4a039 = m
		mode: import
		source = ```
				let
				    CurrentServer = Instancia,
				    CurrentDatabase = BaseDeDatos,
				    CurrentSchema = Esquema,
				    Origen = Sql.Database(CurrentServer, CurrentDatabase, [Query="
				                                                                SELECT  
				                                                                    CPY_0 AS 'Empresa',
				                                                                    CPYNAM_0 AS 'Nombre Empresa',
				                                                                    BPAADD_0 AS 'Direccion',
				                                                                    (CPY_0+'-'+BPAADD_0) AS 'IdDireccion',
				                                                                    CPYLEGFLG_0 AS 'Sociedad Juridica',
				                                                                    LEG_0 AS 'Legislacion',
				                                                                    ACM_0 AS 'Modelo Contable',
				                                                                    MAIFCY_0 AS 'Planta Principal',
				                                                                    CRY_0 AS 'Pais'
				                                                                FROM " & CurrentSchema & ".COMPANY"
				                                                          ])
				in
				    #"Origen"
				```

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

